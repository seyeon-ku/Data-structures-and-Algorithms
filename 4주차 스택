#include<stdio.h>
#include<stdlib.h>
#include<time.h>
#pragma warning (disable:4996)
typedef char element;
typedef struct {
	element *ch;
	int capacity;
    int top;
} StackType;
void inti(StackType* s) {
	s->top = -1;
	s->capacity = 1;
	s->ch = (element*)malloc(sizeof(element));
	if (s->ch == NULL)
		return;
}
void delete(StackType* s) {
	free(s->ch);
	free(s); 
}
int is_full(StackType* s);
int is_empty(StackType* s);
void push(StackType* s, element item);
element pop(StackType* s);
int check_matching(char open, char close);

int main() {
	
	StackType* stack = (StackType*)malloc(sizeof(StackType));
	inti(stack);
	char ch, top;
	int i = 0, N = 0, cnt = 0, t = 1;
	while (i < 1000 && (ch = getchar()) != '\n') {
		if (ch == '(' || ch == '{' || ch == '[') {
			cnt++;
			push(stack, ch);
		}
		else if (ch == ')' || ch == '}' || ch == ']') {
			cnt++;
			if (is_empty(stack))
				t = 0;
			else {
				top = pop(stack);
				if (!check_matching(top, ch))
					t = 0;
			}
		}
		i++;
	}
	if (is_empty(stack) == 0)
		t = 0;
	if (t == 1)
		printf("OK_%d", cnt);
	else
	    printf("Wrong_%d", cnt);
	
	delete(stack);
	return 0;
}
int is_full(StackType* s) {
	if (s->capacity - 1 == s->top) {
		return 1;
	}
	return 0;
}
int is_empty(StackType* s) {
	if (s->top == -1) {
		return 1;
	}
	return 0;
}
void push(StackType* s, element item){
	if (is_full(s)) {
		s->capacity *= 2;
		s->ch = (element*)realloc(s->ch, s->capacity * sizeof(element));
		if (s->ch == NULL)
			return;
	}
	s->ch[++(s->top)] = item;
}
element pop(StackType* s) {
	if (is_empty(s)) {
		return 0;
	}
	return s->ch[s->top--];
}
int check_matching(char open, char close) {
	if (open == '(' && close == ')')
		return 1;
	if (open == '{' && close == '}')
		return 1;
	if (open == '[' && close == ']')
		return 1;
	return 0;
}
