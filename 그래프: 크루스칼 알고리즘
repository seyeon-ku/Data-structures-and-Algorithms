#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#pragma warning(disable:4996)

#define TRUE 1
#define FALSE 0
#define MAX_VERTICES 100
#define INF 1000

int parent[MAX_VERTICES];

void set_init(int n) {
    for (int i = 0; i < n; i++) {
        parent[i] = -1;
    }
}
int set_find(int curr) { //루트 노드 찾기
    if (parent[curr] == -1)
        return curr;
    while (parent[curr] != -1)
        curr = parent[curr];
    return curr;
}
void set_union(int a, int b) {
    int root1 = set_find(a);
    int root2 = set_find(b);
    if (root1 != root2) //부모 노드가 다르면
        parent[root1] = root2; // 합침
}
struct Edge {   // 간선을나타내는구조체
    int start, end, weight;
};
typedef struct GraphType {
    int no_v;  // 정점의개수
    int no_e;  // 간선의개수
    struct Edge edges[2 * MAX_VERTICES];
} GraphType;

void graph_init(GraphType* g, int v) {
    g->no_v = v;
    g->no_e = 0;
}

void insert_edge(GraphType* g, int start, int end, int w) {
    if (g->no_e >= 2 * MAX_VERTICES) {
        fprintf(stderr, "간선의수가최대값을초과함.\n");
        return;
    }
    g->edges[g->no_e].start = start;
    g->edges[g->no_e].end = end;
    g->edges[g->no_e].weight = w;
    g->no_e++;
}
int compare(const void* a, const void* b) // qsort()에 사용되는 함수 (void: 자료형 타입 정하지 않음, const: 절대 변경 불가)
{
    struct Edge* x = (struct Edge*)a;
    struct Edge* y = (struct Edge*)b;
    if (x->weight == y->weight)
        return x->start - y->start; // 가중치가 같으면 시작 정점 기준 정렬
    return (x->weight - y->weight);  // 가중치 기준 정렬
}

void kruskal(GraphType* g) {  // kruskal의 최소 비용 신장 트리 프로그램
    int edge_accepted = 0;  // 현재까지 선택된 간선의 수
    int uset, vset;   // 정점u와 정점v의 집합 번호
    struct Edge e;
    set_init(g->no_v);   // 집합 초기화
    qsort(g->edges, g->no_e, sizeof(struct Edge), compare); // 배열 주소, 개수, 크기, 기준
    printf("크루스칼최소신장트리알고리즘\n");
    int i = 0;
    while (edge_accepted < (g->no_v - 1) && i < g->no_e){
        e = g->edges[i]; // edges 정렬 된 상태
        uset = set_find(e.start); // 정점 u의 집합 번호
        vset = set_find(e.end);  // 정점 v의 집합 번호
        if (uset != vset) {  // 서로 속한 집합이 다르면(즉, cycle이 안생기면)
            printf("간선(%d,%d) %d 선택\n", e.start, e.end, e.weight);
            edge_accepted++;
            set_union(uset, vset); // 두개의 집합을 합친다.
        }
        i++;
    }
    if (edge_accepted < g->no_v - 1) {
        printf("오류: 그래프가연결되어있지않아최소신장트리생성불가\n");
    }
}
