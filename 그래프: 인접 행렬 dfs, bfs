#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#pragma warning(disable:4996)

#define MAX_VERTICES 50
typedef struct { // 인접행렬 그래프 타입
    int adj_mat[MAX_VERTICES][MAX_VERTICES];
    int n; //정점 개수
} GraphType;

void init(GraphType* g) { // 인접행렬 초기화
    for (int i = 0; i < MAX_VERTICES; i++) {
        for (int j = 0; j < MAX_VERTICES; j++) {
            g->adj_mat[i][j] = 0;
        }
    }
    g->n = 0;
}

int visited[MAX_VERTICES];

void insert_vertex(GraphType* g, int v) { // 인접행렬 정점 삽입
    if (((g->n) + 1) > MAX_VERTICES) {
        return;
    }
    g->n++;
}

void insert_edge(GraphType* g, int start, int end) { // 인접행렬 간선 삽입
    if (start >= g->n || end >= g->n) {
        return;
    }
    g->adj_mat[start][end] = 1;
    g->adj_mat[end][start] = 1;
}

void dfs_mat(GraphType* g, int v) { //인접행렬 dfs 탐색
    visited[v] = 1;

    for (int w = 0; w < g->n; w++) {
        if (g->adj_mat[v][w] == 1 && visited[w] == 0) {
            dfs_mat(g, w);
        }
    }
}
typedef struct QueueType {
    int queue[MAX_VERTICES];
    int front, rear;
} QueueType;

void init_queue(QueueType* q) {
    q->front = -1;
    q->rear = -1;
}
int is_empty(QueueType* q) {
    return q->front == q->rear;
}
int is_full(QueueType* q) {
    return q->rear == MAX_VERTICES - 1;
}
void enqueue(QueueType* q, int item) {
    if (is_full(q)) {
        return;
    }
    q->rear++;
    q->queue[q->rear] = item;
}
int dequeue(QueueType* q) {
    if (is_empty(q)) {
        return -1;
    }
    q->front++;
    return q->queue[q->front];
}
void bfs_mat(GraphType * g, int v) { // 인접행렬 bfs 탐색

    QueueType q;
    init_queue(&q);
    visited[v] = 1;
    enqueue(&q, v);

    while (!is_empty) {
        int x = dequeue(&q);
        for (int w = 0; w < g->n; w++) {
            if (g->adj_mat[v][w] && !visited[w]) {
                visited[w] = 1;
                enqueue(&q, w);
            }
        }
    }
}
