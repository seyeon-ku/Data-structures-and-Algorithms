int search_binary2(int key, int low, int high) { // 이진 탐색, 정렬된 자료
    int middle;
    while (low <= high) { 
        middle = (low + high) / 2;
        if (key == list[middle])
            return middle;
        else if (key < list[middle])
            high = middle - 1; // low부터 middle - 1까지 탐색하게 해줌
        else
            low = middle + 1; // middle + 1 부터 high 까지 탐색하게 해줌
    }
    return -1;
}

int interpol_search(int key, int n){ // 보간 탐색, 정렬된 배열에서만, j식 외우기
    int low, high, j;
    low = 0;
    high = n - 1;
    while ((list[high] >= key) && (key > list[low])) {
        j = ((float)(key - list[low]) / (list[high] - list[low])*(high - low)) + low;
        if (key > list[j])
            low = j + 1;
        else if (key < list[j])
            high = j - 1;
        else
            low = j;
    }
    if (list[low] == key)
        return(low);
    else
        return -1;
}

typedef struct Node {
    int key;
    struct Node* left;
    struct Node* right;
    int height;
} Node;

Node* create_node(int key) {
    Node* new_node;

    new_node->key = key;
    new_node->left = NULL;
    new_node->right = NULL;
    new_node->height = 1;

    return new_node;
}
int get_height(Node* n) {
    if (n == NULL) 
        return 0;
    return n->height;
}

Node* min_value_node(Node* node) {
    Node* current = node;
    while (current->left != NULL) {
        current = current->left;
    }
    return current;
}
int get_balance(Node* N) {
    if (N == NULL)
        return 0;
    return get_height(N->left) - get_height(N->right);
}
Node* right_rotate(Node* y) {
    Node* x = y->left;
    Node* T2 = x->right;

    x->right = y;
    y->left = T2;

    y->height = max(get_height(y->left), get_height(y->right)) + 1;
    x->height = max(get_height(x->left), get_height(x->right)) + 1;

    return x;
}
Node* left_rotate(Node* y) {
    Node* x = y->right;
    Node* T2 = x->left;

    x->left = y;
    y->right = T2;

    x->height = max(get_height(x->left), get_height(x->right)) + 1;
    y->height = max(get_height(y->left), get_height(y->right)) + 1;
    return x;
}

Node* insert(Node* node, int key) {
    if (node == NULL) return create_node(key); // 베이스 케이스, 트리의 끝에 도달했을 때 아무 노드 없으므로

    if (key < node->key) {
        node->left = insert(node->left, key);
    }
    else if (key > node->key) {
        node->right = insert(node->right, key);
    }
    else
        return node;
    
    node->height = 1 + max(get_height(node->left), get_height(node->right));
    int balance = get_balance(node);
    // [경우 1] LL (Left Left) 상태 -> 우회전, 새로 들어온 key가 왼쪽에 삽입돼서 균형이 깨진 경우
    if (balance > 1 && key < node->left->key) {
        return right_rotate(node);
    }

    // [경우 2] RR (Right Right) 상태 -> 좌회전
    if (balance < -1 && key > node->right->key) {
        return left_rotate(node);
    }

    // [경우 3] LR (Left Right) 상태 -> 좌회전 후 우회전
    if (balance > 1 && key > node->left->key) {
        node->left = left_rotate(node->left);
        return right_rotate(node);
    }

    // [경우 4] RL (Right Left) 상태 -> 우회전 후 좌회전
    if (balance < -1 && key < node->right->key) {
        node->right = right_rotate(node->right);
        return left_rotate(node);
    }
    return node;
}

Node* delete_node(Node* root, int key) {
    // STEP 1: 일반 BST의 삭제 연산 수행
    if (root == NULL) return root;

    // 삭제할 값이 현재 노드보다 작으면 왼쪽으로
    if (key < root->key) {
        root->left = delete_node(root->left, key);
    }
    // 삭제할 값이 현재 노드보다 크면 오른쪽으로
    else if (key > root->key) {
        root->right = delete_node(root->right, key);
    }
    // 삭제할 노드를 찾은 경우
    else {
        // 자식이 없거나 하나만 있는 경우
        if ((root->left == NULL) || (root->right == NULL)) {
            Node* temp = root->left ? root->left : root->right;

            // 자식이 없는 경우
            if (temp == NULL) {
                temp = root; // 주소 백업
                root = NULL;
            }
            else { // 자식이 하나 있는 경우
                *root = *temp; // 자식의 내용을 현재 노드로 복사
            }
            free(temp);
        }
        else {
            // 자식이 둘 다 있는 경우: 오른쪽 서브트리에서 가장 작은 값(후계자)을 찾음
            Node* temp = min_value_node(root->right);

            // 후계자의 값을 현재 노드에 덮어씀
            root->key = temp->key;

            // 오른쪽 서브트리에서 후계자를 삭제함
            root->right = delete_node(root->right, temp->key);
        }
    }

    // 노드가 하나뿐이어서 삭제 후 트리가 비었다면 리턴
    if (root == NULL) return root;

    // STEP 2: 현재 노드의 높이 갱신
    root->height = 1 + max(get_height(root->left), get_height(root->right));

    // STEP 3: 균형 인수 확인
    int balance = get_balance(root);

    // [균형잡기 1] LL 상태
    if (balance > 1 && get_balance(root->left) >= 0) {
        return right_rotate(root);
    }

    // [균형잡기 2] LR 상태
    if (balance > 1 && get_balance(root->left) < 0) {
        root->left = left_rotate(root->left);
        return right_rotate(root);
    }

    // [균형잡기 3] RR 상태
    if (balance < -1 && get_balance(root->right) <= 0) {
        return left_rotate(root);
    }

    // [균형잡기 4] RL 상태
    if (balance < -1 && get_balance(root->right) > 0) {
        root->right = right_rotate(root->right);
        return left_rotate(root);
    }

    return root;
}
