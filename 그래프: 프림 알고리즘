#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#pragma warning(disable:4996)

#define TRUE 1
#define FALSE 0
#define MAX_VERTICES 100
#define INF 1000L
int parent[MAX_VERTICES]; // 부모노드

typedef struct GraphType {
    int n; // 정점의개수
    int weight[MAX_VERTICES][MAX_VERTICES];
} GraphType;

int selected[MAX_VERTICES], distance[MAX_VERTICES];

int get_min_vertex(int n) { // 최소dist[v] 값을갖는정점을반환
    int v, i;
    for (i = 0; i < n; i++)
        if (!selected[i]) {
            v = i; //아무거나 선택 안된거
            break;
        }
    for (i = 0; i < n; i++) //선택되지 않은 정점 중 디스턴스 값이 가장 작은 것 선발
        if (!selected[i] && (distance[i] < distance[v]))
            v = i;
    return (v);
}

void prim(GraphType* g, int s) { //시작 노드 s
    int i, u, v;
    for (u = 0; u < g->n; u++) {
        distance[u] = INF; //초기화
        parent[u] = -1; // cycle check은필요없으나, 간선을표기하기위해서필요함.
    }
    distance[s] = 0; //자기자신이므로 0
    for (i = 0; i < g->n; i++) {
        u = get_min_vertex(g->n);
        selected[u] = TRUE; //거리 가장 짧은 노드 편입
        if (distance[u] == INF) return; // 인접하지않은정점이선택된경우(오류처리)
        if (parent[u] != -1)
            printf("간선추가: (% d, % d), 가중치 % d\n", parent[u], u, distance[u]);
        else
            printf("시작정점 % d 추가\n", u);
        for (v = 0; v < g->n; v++) { // 거리 갱신
            if (g->weight[u][v] != INF) {
                if (!selected[v] && g->weight[u][v] < distance[v]) {
                    distance[v] = g->weight[u][v];
                    parent[v] = u;
                    // v의최단거리를u가갱신함.
                }
            }
        }
    }
}
