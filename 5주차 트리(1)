#include<stdio.h>
#include<stdlib.h>
#include<time.h>
#pragma warning (disable:4996)
#define Max_size 8

typedef struct TreeNode {
	int data;
	struct TreeNode* left, * right;
}TreeNode;
TreeNode* insert(int n, TreeNode* F1, TreeNode* F2);
typedef TreeNode* element;
typedef struct QueueType {
	element data[Max_size];
	int front, rear;
}QueueType;
void init_que(QueueType * q);
void enQueue(QueueType* q, element e);
element deQueue(QueueType* q);
int is_full(QueueType* q);
int is_empty(QueueType* q);
void level_order(TreeNode* ptr, int n);
int main() {

	TreeNode* F1, * F2, * F3, * F4, * F5, * F6, * F7, * F8;
	
	F7 = insert(130, NULL, NULL);
	F8 = insert(80, NULL, NULL);
	F6 = insert(120, F7, F8);

	F4 = insert(70, NULL, NULL);
	F5 = insert(90, NULL, NULL);
	F2 = insert(30, F4, F5);

	F3 = insert(50, NULL, F6);
	F1 = insert(20, F2, F3);

	int n;
	scanf("%d", &n);

	level_order(F1, n);
	if (n < 1 || n > 8) {
		printf("-1");
		return 0;
	}

	return 0;
	
}
TreeNode* insert(int n, TreeNode* F1, TreeNode* F2){
	TreeNode* NewNode;
	NewNode = (TreeNode*)malloc(sizeof(TreeNode));
	NewNode->data = n;
	NewNode->left = F1;
	NewNode->right = F2;
	return NewNode;
}
void init_que(QueueType* q) {
	q->front = 0;
	q->rear = 0;
}
void enQueue(QueueType* q, element e) {
	if (is_full(q)) {
		return;
	}
	q->rear = (q->rear + 1) % Max_size;
	q->data[q->rear] = e;
}
element deQueue(QueueType* q) {
	if (is_empty(q))
		return NULL;
	q->front = (q->front + 1) % Max_size;
	return q->data[q->front];
}
int is_full(QueueType* q) {
	if (q->front == (q->rear + 1) % Max_size)
		return 1;
	return 0;
}
int is_empty(QueueType* q) {
	if (q->front == q->rear)
		return 1;
	return 0;
}
void level_order(TreeNode* ptr, int n) {
	QueueType* Q = (QueueType*)malloc(sizeof(QueueType));
	init_que(Q);

	if (ptr == NULL)
		return;
	int cnt = 0;
	enQueue(Q, ptr);

	while (!is_empty(Q)) {
		TreeNode* tmp = deQueue(Q);
		cnt++;
		if (cnt == n) {
			printf("%d ", tmp->data);
			if (tmp->left != NULL)
				printf("%d ", tmp->left->data);
			if (tmp->right != NULL)
				printf("%d ", tmp->right->data);
		    return;
		}
		if (tmp->left != NULL)
			enQueue(Q, tmp->left);

		if (tmp->right != NULL)
			enQueue(Q, tmp->right);
	}
}
